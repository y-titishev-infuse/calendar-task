AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (Web client). Authorized redirect URI in Google Cloud:
#   http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Infuse LLM orchestrator (Anthropic-compatible proxy with Bearer auth).
LLM_ORCHESTRATOR_BASE_URL=https://llm-orchestrator.infuse.com/proxy/anthropic
LLM_ORCHESTRATOR_API_KEY=

# Jira (Atlassian Cloud). API token from:
#   https://id.atlassian.com/manage-profile/security/api-tokens
# Tasks are pushed to JIRA_PROJECT_KEY as JIRA_ISSUE_TYPE.
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Task
