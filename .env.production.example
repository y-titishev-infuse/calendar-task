# Copy to .env.production on the server and fill in real values.
# This file is loaded by docker-compose via `env_file:`.

# Public URL of the deployed app (no trailing slash).
# Must match what users type into the browser AND the Google OAuth redirect URI.
NEXTAUTH_URL=https://your-domain.example.com

# Random 32-byte base64 string. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (Web client). Authorized redirect URI in Google Cloud:
#   https://your-domain.example.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Infuse LLM orchestrator (Anthropic-compatible proxy with Bearer auth).
LLM_ORCHESTRATOR_BASE_URL=https://llm-orchestrator.infuse.com/proxy/anthropic
LLM_ORCHESTRATOR_API_KEY=

# Jira (Atlassian Cloud). API token from:
#   https://id.atlassian.com/manage-profile/security/api-tokens
# Approved tasks are pushed to JIRA_PROJECT_KEY as JIRA_ISSUE_TYPE.
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Task

# Optional: which host port to expose. Container always listens on 3000.
# HOST_PORT=3000
